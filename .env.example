# Telegram
BOT_TOKEN=123456:your-telegram-bot-token-from-botfather
ALLOWED_USER_ID=000000000
# Optional: proxy for reaching api.telegram.org from Docker
# Examples: http://user:pass@host:port  /  socks5://host:1080  /  http://host.docker.internal:7890
# TELEGRAM_PROXY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (for voice transcription, optional)
OPENROUTER_API_KEY=sk-or-v1-...
ENABLE_VOICE=true

# Supabase / Postgres (use DATABASE_URL with sslmode=require)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# User defaults (saved into profile on /start)
DEFAULT_TIMEZONE=Asia/Bangkok
DEFAULT_DISPLAY_NAME=

# Models
LLM_MAIN_MODEL=claude-sonnet-4-6
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=BAAI/bge-m3

# App
LOG_LEVEL=INFO
ENV=dev
